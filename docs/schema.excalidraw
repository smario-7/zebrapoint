    {
      "id": "lnRCmoU_olWBvsoGFBDpb",
      "type": "text",
      "x": -1685.434998895852,
      "y": 1914.5507137025497,
      "width": 669.87939453125,
      "height": 600,
      "angle": 0,
      "strokeColor": "#1e1e1e",
