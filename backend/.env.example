# =============================================================================
# ZebraPoint — backend (.env)
# Skopiuj do .env i uzupełnij wartości. Pliku .env nie commituj.
# =============================================================================

# -----------------------------------------------------------------------------
# Baza danych (PostgreSQL / Supabase)
# -----------------------------------------------------------------------------
# Direct (IPv6): postgresql://postgres:HASŁO@db.PROJEKT.supabase.co:5432/postgres
# Bez IPv6 — Session mode z Dashboard → Connect: host aws-0-REGION.pooler.supabase.com
# Session: postgres://postgres.REF:HASŁO@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:PASSWORD@db.REF.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# JWT (sesje API)
# -----------------------------------------------------------------------------
# Min. 32 znaki (walidacja przy starcie)
SECRET_KEY=change-me-to-at-least-32-characters-long-secret
# Lokalnie HTTP: false. Produkcja HTTPS: true lub ustaw ENVIRONMENT=production
COOKIE_SECURE=false
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Redis (broker Celery, metryki AI, cache)
# -----------------------------------------------------------------------------
# Docker Compose: host „redis”, port 6379
# Lokalnie bez Dockera: redis://127.0.0.1:6379/0
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# OpenAI (opisy grup; bez klucza pole ai_description zostaje puste)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Środowisko i zachowanie aplikacji
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
# true = ładowanie modelu embeddingów przy starcie API (wolniejszy start)
LOAD_EMBEDDINGS_ON_STARTUP=false

# -----------------------------------------------------------------------------
# CORS (dozwolone originy frontu)
# -----------------------------------------------------------------------------
# Development: zwykle puste — main.py ma localhost wbudowany.
# Production: lista po przecinku, np. https://app.domena.pl,https://admin.domena.pl
FRONTEND_ORIGINS=

# -----------------------------------------------------------------------------
# Logi i snapshoty na dysku (ścieżka do katalogu)
# -----------------------------------------------------------------------------
# Puste = katalog logs/ obok folderu backend/ (np. zebrapoint/logs/).
# Docker Compose nadpisuje zwykle na /logs (volume).
# Lokalnie nie ustawiaj LOG_DIR=/logs — to ścieżka systemowa bez uprawnień.
LOG_DIR=
