# Baza danych (Supabase)
# Direct (IPv6): postgresql://postgres:PASSWORD@db.REF.supabase.co:5432/postgres
# Przy braku IPv6 używaj Session mode z Dashboard (Connect → Session mode): host aws-0-REGION.pooler.supabase.com
# Session mode: postgres://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:PASSWORD@db.REF.supabase.co:5432/postgres

# JWT
SECRET_KEY=your-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Środowisko
ENVIRONMENT=development
DEBUG=true
